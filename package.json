    "firebender",
    "forgecode",
    "gemini-cli",
    "github-copilot",
    "goose",
    "hermes-agent",
    "inference-sh",
    "jazz",
    "junie",
    "iflow-cli",
    "kilo",
    "kimi-code-cli",
    "kiro-cli",
    "kode",
    "lingma",
    "loaf",
    "mcpjam",
    "mistral-vibe",
    "moxby",
    "mux",
    "opencode",
    "openhands",
